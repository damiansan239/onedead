{
  "hosting": {
    "public": "dist",
    "predeploy": "yarn --cwd \"$RESOURCE_DIR\" run build",
    "ignore": [
      "**/.*",
      "firebase.json",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html",
        "pre-deploy": "yarn --cwd \"$RESOURCE_DIR\" run build"
      }
    ]
  },
  "remoteconfig": {
    "template": "firebase/remoteconfig.template.json"
  },
  "firestore": {
    "location": "nam5",
    "database": "(default)",
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "database": {
    "rules": "firebase/database.rules.json"
  },
  "functions": [
    {
      "runtime": "nodejs20",
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "yarn --cwd \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}