{
  "hosting": {
    "public": "dist",
    "predeploy": "bun --bun run build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html",
        "pre-deploy": "bun --bun run build"
      }
    ]
  },
  "remoteconfig": {
    "template": "firebase/remoteconfig.template.json"
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "database": {
    "rules": "firebase/database.rules.json"
  }
}
